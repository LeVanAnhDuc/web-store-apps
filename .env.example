# ─────────────────────────────────────────────────────────────────────────────
# App — runtime variables consumed by Next.js (next.config.ts + src/)
# ─────────────────────────────────────────────────────────────────────────────

# Internal: path prefix for all API requests (rewritten by next.config.ts)
NEXT_PUBLIC_API_PREFIX=/api/v1

# Backend origin that next.config.ts rewrites NEXT_PUBLIC_API_PREFIX to
API_SERVER_URL=http://localhost:5000

# Public site origin used for SEO / robots.txt (defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# E2E / Playwright — only needed when running `yarn e2e`
# ─────────────────────────────────────────────────────────────────────────────

# Base URL the Playwright browser navigates to.
# Overrides the .worktree-state.json lookup and the default http://localhost:3000.
E2E_BASE_URL=http://localhost:3000

# Seeded regular-user credentials (role: user)
E2E_USER_EMAIL=user@test.com
E2E_USER_PASSWORD=User@123

# Seeded admin credentials (role: admin)
E2E_ADMIN_EMAIL=admin@test.com
E2E_ADMIN_PASSWORD=Admin@123
